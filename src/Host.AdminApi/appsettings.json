{
  "ApplicationIdentity": {
    "DisplayName": "GenericModularApi",
    "Namespace": "gma"
  },
  "Persistence": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "SqlServer": "",
    "PostgreSql": "",
    "nats": ""
  },
  "Tenancy": {
    "Enabled": true,
    "HeaderName": "X-Tenant-Id",
    "LocalDefaultTenantId": "default"
  },
  "Caching": {
    "Enabled": false,
    "Provider": "Memory",
    "DefaultDistributedExpiration": "00:05:00",
    "DefaultLocalExpiration": "00:00:30",
    "MaximumPayloadBytes": 1048576,
    "MaximumKeyLength": 1024,
    "Redis": {
      "ConnectionName": "redis"
    }
  },
  "Outbox": {
    "BatchSize": 25,
    "PollIntervalMilliseconds": 5000,
    "LockDurationMilliseconds": 60000,
    "MaxAttempts": 10
  },
  "NatsJetStream": {
    "Enabled": false
  },
  "NatsConsumers": {
    "Enabled": false,
    "FetchBatchSize": 10,
    "PollInterval": "00:00:01",
    "AckWait": "00:00:30",
    "MaxDeliver": 5,
    "HandlerTimeout": "00:00:30",
    "NakDelay": "00:00:01"
  },
  "Observability": {
    "Prometheus": {
      "Enabled": false,
      "EndpointPath": "/metrics"
    },
    "Otlp": {
      "Enabled": false,
      "Endpoint": null,
      "ExportMetrics": true,
      "ExportTraces": true,
      "ExportLogs": true
    }
  },
  "Auth": {
    "RefreshTokenLifetimeDays": 30,
    "RefreshTokens": {
      "Pepper": ""
    },
    "Jwt": {
      "SigningKey": "",
      "AccessTokenLifetimeMinutes": 15
    }
  },
  "Administration": {
    "Api": {
      "ActorIdClaim": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier",
      "TenantIdClaim": "tenant_id",
      "RequireTenantClaimMatch": true,
      "AllowGeneratedPasswordResponses": false
    },
    "Bootstrap": {
      "AllowWhenAssignmentsExist": false,
      "OwnerRoleName": "owner"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
